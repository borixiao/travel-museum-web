    "firebase": "^12.15.0",
    "form-data": "^4.0.6",
    "multer": "^2.2.0",
    "node-fetch": "^3.3.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "three": "^0.185.1"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.185.0",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
